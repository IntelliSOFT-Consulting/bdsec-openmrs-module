<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<!--
    OpenMRS module loader reads this file and merges the <mapping> entries
    into the main Hibernate session factory.  This is the correct mechanism
    for registering module entities in all OpenMRS versions (1.9 – 2.x).
-->
<hibernate-configuration>
    <session-factory>
        <mapping class="org.openmrs.module.odooconnector.OdooBillingPaymentStatus"/>
    </session-factory>
</hibernate-configuration>
