	<!-- Required Global Properties -->

	<!-- Odoo connection settings — shared by all Odoo integration services -->
	<globalProperty>
		<property>odooconnector.odooUrl</property>
		<defaultValue>https://bdsec.grace-erp-consultancy.com</defaultValue>
		<description>
			Base URL of the Odoo server (no trailing slash). Used by all Odoo integration services.
			Auth endpoint:  {odooUrl}/web/session/authenticate
			Sales endpoint: {odooUrl}{odooconnector.consultation.odooPath}
		</description>
	</globalProperty>
	<globalProperty>
		<property>odooconnector.odooDb</property>
		<defaultValue>odoo</defaultValue>
		<description>
			Odoo database name sent in the JSON-RPC authentication payload.
		</description>
	</globalProperty>
	<globalProperty>
		<property>odooconnector.odooLogin</property>
		<defaultValue>emrsync</defaultValue>
		<description>
			Odoo service-account login used for API authentication.
		</description>
	</globalProperty>
	<globalProperty>
		<property>odooconnector.odooPassword</property>
		<defaultValue>Admin123</defaultValue>
		<description>
			Odoo service-account password. Change to a strong value in production.
		</description>
	</globalProperty>

	<!-- Consultation-specific settings -->
	<globalProperty>
		<property>odooconnector.consultation.odooPath</property>
		<defaultValue>/api/bdsec/sales</defaultValue>
		<description>
			Odoo API path for the consultation sale order endpoint.
			Combined with odooconnector.odooUrl to form the full URL.
			Full default: https://bdsec.grace-erp-consultancy.com/api/bdsec/sales
		</description>
	</globalProperty>
	<globalProperty>
		<property>odooconnector.consultation.shopId</property>
		<defaultValue>1</defaultValue>
		<description>
			Odoo shop_id sent in every consultation sale order. Identifies which POS shop
			the consultation is billed through. Change per deployment if multiple shops exist.
		</description>
	</globalProperty>
	<globalProperty>
		<property>odooconnector.consultation.connectTimeoutSeconds</property>
		<defaultValue>15</defaultValue>
		<description>
			Max seconds to wait for the TCP/TLS connection to Odoo to establish (auth and sales
			calls). Increase if the network path to Odoo is slow.
		</description>
	</globalProperty>
	<globalProperty>
		<property>odooconnector.consultation.readTimeoutSeconds</property>
		<defaultValue>30</defaultValue>
		<description>
			Max seconds to wait for Odoo's response once a request has been sent. Covers Odoo-side
			processing time for authentication and sale order creation.
		</description>
	</globalProperty>
	<globalProperty>
		<property>odooconnector.consultation.maxRetries</property>
		<defaultValue>2</defaultValue>
		<description>
			Number of automatic retries (in addition to the first attempt) on connection-level
			failures only (DNS failure, connection refused, connect-phase timeout). Read-timeouts
			after a request was already sent to Odoo are never auto-retried, to avoid creating
			duplicate sale orders.
		</description>
	</globalProperty>
	<globalProperty>
		<property>odooconnector.consultation.retryBackoffMillis</property>
		<defaultValue>1500</defaultValue>
		<description>
			Base backoff delay in milliseconds before each retry, multiplied by the attempt number
			(e.g. 1500ms before retry 1, 3000ms before retry 2).
		</description>
	</globalProperty>

	<!-- Billing gate settings -->
	<globalProperty>
		<property>odooconnector.billing.gateEnabled</property>
		<defaultValue>true</defaultValue>
		<description>
			Set to false to disable the billing payment gate globally (e.g. during go-live testing).
			When true, encounters and orders are blocked for patients with unpaid consultations.
		</description>
	</globalProperty>
	<globalProperty>
		<property>odooconnector.billing.emergencyBypassPatients</property>
		<defaultValue></defaultValue>
		<description>
			Comma-separated patient identifiers (e.g. ABC200001,ABC200002) that bypass the billing gate.
			Use for emergency patients who must be treated before payment is collected.
		</description>
	</globalProperty>

	<!-- Inbound billing orders from Odoo (BillingOrderController) -->
	<globalProperty>
		<property>odooconnector.billing.inboundBearerToken</property>
		<defaultValue>test-token-123</defaultValue>
		<description>
			Bearer token Odoo must send in the Authorization header when posting to
			/odooconnector/billing/orders. Change this to a strong random value in production.
		</description>
	</globalProperty>
	<globalProperty>
		<property>odooconnector.billing.inboundApiKey</property>
		<defaultValue></defaultValue>
		<description>
			Alternative API key accepted in the x-api-key header for systems that cannot
			send a Bearer token. Leave blank to disable API-key auth.
		</description>
	</globalProperty>

